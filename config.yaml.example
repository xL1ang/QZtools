# 填你要用的 provider 名字：claude / openai / deepseek
use_provider: "deepseek"

providers:
  claude:
    api_key: ""
    base_url: "https://api.anthropic.com/v1"
    model: "claude-sonnet-4-20250514"
  openai:
    api_key: ""
    base_url: "https://api.openai.com/v1"
    model: "gpt-4o"
  deepseek:
    api_key: ""
    base_url: "https://api.deepseek.com"
    model: "deepseek-chat"
